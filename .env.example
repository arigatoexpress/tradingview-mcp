# TradingView Premium Session Cookies
# Extract from browser DevTools > Application > Cookies > tradingview.com
TRADINGVIEW_SESSION_ID=your_session_id_here
TRADINGVIEW_SESSION_ID_SIGN=your_session_id_sign_here

# Optional: Webhook listener for Sapphire integration
WEBHOOK_PORT=3456
WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Sapphire API endpoint for forwarding signals
SAPPHIRE_API_URL=http://localhost:8000
SAPPHIRE_API_KEY=your_sapphire_api_key_here
